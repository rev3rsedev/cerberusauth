# CerberusAuth configuration — 12-factor, everything via environment.
# Copy to .env for docker compose, or export in your shell.

# --- Required ---

# PostgreSQL connection string.
CERBERUS_DATABASE_URL=postgres://cerberus:cerberus@localhost:5432/cerberus?sslmode=disable

# 32 bytes, base64. Encrypts per-app Ed25519 signing keys at rest and peppers
# email hashes. Generate with: cerberusd genkey   (or: make genkey)
# LOSING THIS KEY means every app's signing key becomes undecryptable and all
# admin logins break. Back it up like a private key, because it is one.
CERBERUS_MASTER_KEY=

# --- Optional (defaults shown) ---

# Address the HTTP server binds to.
CERBERUS_LISTEN_ADDR=:8080

# Accepted clock drift between client timestamp and server time.
CERBERUS_CLOCK_SKEW=5m

# Admin bearer token lifetime.
CERBERUS_ADMIN_TOKEN_TTL=24h

# Apply pending migrations on startup.
CERBERUS_AUTO_MIGRATE=true

# If set and no admin with this email exists, one is created on startup.
# Idempotent — safe to leave set across restarts.
#CERBERUS_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
#CERBERUS_BOOTSTRAP_ADMIN_PASSWORD=change-me-please

# The server refuses to run with the published dev master key from
# docker-compose.yml unless this is true. Never set it in production; it
# exists only so throwaway sandboxes can use the shipped compose file as-is.
#CERBERUS_DEV_MODE=false
